# 目标架构设置
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 核心 UI 与 iStoreOS 特色插件 (精简版只留这两个)
CONFIG_PACKAGE_luci-app-istore=y
CONFIG_PACKAGE_luci-app-quickstart=y

# 基础磁盘与文件系统支持 (x86 必备)
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fuse=y

# 必备的驱动程序 (确保兼容性)
CONFIG_PACKAGE_kmod-intel-igb=y
CONFIG_PACKAGE_kmod-intel-igc=y
CONFIG_PACKAGE_kmod-r8168=y
CONFIG_PACKAGE_kmod-r8169=y

# 语言包只留中文
CONFIG_LUCI_LANG_zh_Hans=y

# 禁用默认的大型插件 (通过这种方式强制精简)
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
